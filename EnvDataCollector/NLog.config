<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true" throwExceptions="false">
  <targets>
    <target xsi:type="File" name="file"
            fileName="${basedir}/Logs/${shortdate}.log"
            layout="${longdate} [${level:uppercase=true:padding=-5}] [${logger:shortName=true}] ${message}${onexception:inner=${newline}${exception:format=tostring}}"
            archiveEvery="Day" archiveDateFormat="yyyyMMdd" maxArchiveFiles="30"
            encoding="utf-8" keepFileOpen="true" concurrentWrites="false"/>
    <target xsi:type="Memory" name="mem"
            layout="${longdate} [${level:uppercase=true}] [${logger:shortName=true}] ${message}${onexception:inner= | ${exception:format=message}}"/>
  </targets>
  <rules>
    <logger name="*" minlevel="Info"  writeTo="file"/>
    <logger name="*" minlevel="Debug" writeTo="mem"/>
  </rules>
</nlog>
